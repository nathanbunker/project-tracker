<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"https://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="org.openimmunizationsoftware.pt.model">
  <class name="StudentOffer" table="student_offer">
    <id name="studentOfferId" type="java.lang.Integer">
      <column name="student_offer_id" />
      <generator class="native" />
    </id>
    <many-to-one name="contact" column="contact_id" class="ProjectContact" not-null="true" lazy="proxy" fetch="select"/>
    <many-to-one name="studentOfferTemplate" column="student_offer_template_id" class="StudentOfferTemplate" not-null="false" lazy="proxy" fetch="select"/>
    <property name="title" type="string">
      <column name="title" length="200" not-null="true" />
    </property>
    <property name="description" type="text">
      <column name="description" />
    </property>
    <property name="pricePoints" type="java.lang.Integer">
      <column name="price_points" not-null="true" />
    </property>
    <property name="imagePath" type="string">
      <column name="image_path" length="500" />
    </property>
    <property name="status" type="string">
      <column name="status" length="20" not-null="true" />
    </property>
    <property name="displayOrder" type="integer">
      <column name="display_order" not-null="true" />
    </property>
    <property name="createdDate" type="timestamp">
      <column name="created_date" not-null="true" />
    </property>
    <property name="updatedDate" type="timestamp">
      <column name="updated_date" />
    </property>
    <property name="boughtDate" type="timestamp">
      <column name="bought_date" />
    </property>
    <property name="fulfillingDate" type="timestamp">
      <column name="fulfilling_date" />
    </property>
    <property name="deliveredDate" type="timestamp">
      <column name="delivered_date" />
    </property>
    <set name="pointLedgerEntries" inverse="true" lazy="true" fetch="select">
      <key column="student_offer_id" />
      <one-to-many class="GamePointLedger" />
    </set>
  </class>
</hibernate-mapping>
