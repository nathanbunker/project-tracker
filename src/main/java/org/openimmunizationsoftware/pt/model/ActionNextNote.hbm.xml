<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"https://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="org.openimmunizationsoftware.pt.model">
  <class name="ActionNextNote" table="action_next_note">
    <id name="actionNextNoteId" type="int">
      <column name="action_next_note_id" />
      <generator class="native" />
    </id>
    <property name="actionNextId" type="int">
      <column name="action_next_id" not-null="true" />
    </property>
    <many-to-one name="actionNext" column="action_next_id" class="ActionNext" insert="false" update="false" lazy="proxy" fetch="select"/>
    <property name="contactId" type="int">
      <column name="contact_id" not-null="true" />
    </property>
    <many-to-one name="contact" column="contact_id" class="ProjectContact" insert="false" update="false" lazy="proxy" fetch="select"/>
    <property name="noteLine" type="string">
      <column name="note_line" not-null="true" />
    </property>
    <property name="noteDate" type="timestamp">
      <column name="note_date" not-null="true" />
    </property>
  </class>
</hibernate-mapping>
