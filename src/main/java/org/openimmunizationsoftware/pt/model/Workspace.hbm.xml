<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"https://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="org.openimmunizationsoftware.pt.model">
    <class name="Workspace" table="workspace">
        <id name="workspaceId" type="int">
            <column name="workspace_id" />
            <generator class="native" />
        </id>
        <property name="workspaceName" type="string">
            <column name="workspace_name" length="100" not-null="true" />
        </property>
        <property name="workspaceType" type="string">
            <column name="workspace_type" length="20" not-null="true" />
        </property>
        <property name="createdByWebUserId" type="int">
            <column name="created_by_web_user_id" not-null="true" />
        </property>
        <property name="workspaceStatus" type="string">
            <column name="workspace_status" length="20" not-null="true" />
        </property>
        <property name="createdDate" type="timestamp">
            <column name="created_date" length="19" not-null="true" />
        </property>
    </class>
</hibernate-mapping>